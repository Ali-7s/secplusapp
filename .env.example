# Copy this file to .env and fill in your values (for local docker-compose only)
# Never commit .env to source control

# Your Anthropic API key — required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT signing secret — must be at least 32 characters, keep it secret!
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Railway/Render only — internal URL to the backend service
# Leave unset for docker-compose (resolved automatically via service name)
# BACKEND_URL=http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:8080

# Optional — restrict CORS to your frontend domain (defaults to * if unset)
# CORS_ORIGINS=https://your-frontend.up.railway.app
